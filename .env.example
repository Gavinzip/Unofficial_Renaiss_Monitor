# Renaiss Market Monitor Configuration

# Discord Webhook URL (Required for alerts)
DISCORD_WEBHOOK_URL="your_discord_webhook_url_here"
# Optional 2nd Discord webhook URL
# DISCORD_WEBHOOK_URL_2="your_second_discord_webhook_url_here"
# Optional multiple webhooks (comma/space/newline separated)
# DISCORD_WEBHOOK_URLS="https://discord.com/api/webhooks/xxx/aaa,https://discord.com/api/webhooks/yyy/bbb"

# 30-day rolling window for price calculation (Default: 30)
WINDOW_DAYS=30

# Price difference threshold to trigger alert (%)
# +10 => only alert when ask is at least 10% below market average (profitable opportunities)
# -10 => allow alerts even if ask is up to 10% above market average
PRICE_DIFF_PERCENT_THRESHOLD=-10.0

# Optional: AI API Keys (Used by market_report_vision.py if needed)
# OPENAI_API_KEY="your_openai_key"
# MINIMAX_API_KEY="your_minimax_key"

# ==============================================
# Twitter Monitor Configuration
# ==============================================
# Discord Webhook URL for Twitter notifications (separate from market alerts)
DISCORD_WEBHOOK_URL_TWITTER="your_discord_webhook_url_for_twitter"

# Twitter accounts to monitor (comma-separated, without @)
TWITTER_ACCOUNTS="pokegetinfomain"

# Check interval in minutes (default: 30)
TWITTER_CHECK_INTERVAL=30
