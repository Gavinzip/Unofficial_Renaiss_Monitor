# Renaiss Market Monitor Configuration

# Discord Webhook URL (Required for alerts)
DISCORD_WEBHOOK_URL="your_discord_webhook_url_here"
# Optional 2nd Discord webhook URL
# DISCORD_WEBHOOK_URL_2="your_second_discord_webhook_url_here"
# Optional multiple webhooks (comma/space/newline separated)
# DISCORD_WEBHOOK_URLS="https://discord.com/api/webhooks/xxx/aaa,https://discord.com/api/webhooks/yyy/bbb"

# 30-day rolling window for price calculation (Default: 30)
WINDOW_DAYS=30

# Price difference threshold to trigger alert ($ USD) (Default: -30)
# Example: -30 triggers if price is <= (Average + 30). 
# Example: 50 triggers if price is <= (Average - 50).
PRICE_THRESHOLD=-30.0

# Optional: AI API Keys (Used by market_report_vision.py if needed)
# OPENAI_API_KEY="your_openai_key"
# MINIMAX_API_KEY="your_minimax_key"
